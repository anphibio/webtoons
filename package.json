{
  "name": "webtoon-image-translator",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "vite build && node scripts/build-content.mjs && node scripts/copy-ocr-assets.mjs",
    "build:ipad": "npm run build && node apps/ipad-safari-extension/scripts/prepare.mjs --backend-origin \"$IPAD_BACKEND_ORIGIN\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "evaluate:ocr": "node scripts/run-evaluate-ocr.mjs",
    "evaluate:ocr:check": "node scripts/run-evaluate-ocr.mjs --check",
    "benchmark:ocr": "node scripts/run-ocr-benchmark.mjs",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.326",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.6.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.6",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tesseract.js": "^7.0.0"
  }
}
