# Copie este arquivo para .env e preencha os dois segredos.
DEEPL_API_KEY=
API_ACCESS_TOKEN=

# Porta publicada pelo QNAP na rede local.
BACKEND_PORT=8000

# Limite de segurança. O backend usa apenas um worker.
BACKEND_MEMORY_LIMIT=4g

# Mantenha somente as origens dos sites de leitura suportados.
CORS_ALLOW_ORIGINS=https://www.toongod.org,https://toongod.org

DEEPL_API_ENDPOINT=https://api-free.deepl.com
OCR_TILE_HEIGHT=1400
OCR_TILE_OVERLAP=160
OCR_DETECTION_MODEL=PP-OCRv5_mobile_det
